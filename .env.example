# Copia este archivo a ".env" y completa tu clave.
# La clave se obtiene en https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-...

# Modelo de Claude a usar (opcional).
#   claude-opus-4-8  -> el más capaz (por defecto)
#   claude-haiku-4-5 -> más rápido y económico, ideal para este agente
ANTHROPIC_MODEL=claude-opus-4-8

# Puerto del servidor (opcional)
PORT=8000
