# Copia este archivo a ".env" y completa tu clave.
# La clave gratuita se obtiene en https://aistudio.google.com/app/apikey

GOOGLE_API_KEY=AIza...

# Modelo de Gemini a usar (opcional).
#   gemini-flash-latest -> flash más reciente, buen uso de herramientas (por defecto)
GOOGLE_MODEL=gemini-flash-latest

# Puerto del servidor (opcional)
PORT=8000
